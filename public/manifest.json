{
  "manifest_version": 3,
  "name": "AP Video Downloader",
  "version": "0.0.0",
  "description": "Downloads AP Daily videos",
  "permissions": ["webRequest", "webNavigation", "tabs", "storage"],
  "host_permissions": ["https://embed-cloudfront.wistia.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
