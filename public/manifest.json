{
  "manifest_version": 3,
  "name": "AP Video Downloader",
  "version": "0.0.0",
  "description": "Downloads AP Daily videos",
  "permissions": ["webRequest", "webRequestBlocking", "tabs", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
