{
  "manifest_version": 3,
  "name": "AP Video Downloader",
  "version": "0.0.0",
  "description": "Downloads AP Daily videos",
  "permissions": ["webRequest", "tabs", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
